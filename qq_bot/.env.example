# --- NoneBot2 Driver ---
DRIVER=~fastapi+~httpx+~websockets+~aiohttp
LOCALSTORE_USE_CWD=true

# --- OneBot V11 WebSocket URL (fill your OneBot bridge address) ---
ONEBOT_WS_URLS=["ws://127.0.0.1:6700"]

# --- Superusers (QQ numbers) ---
# SUPERUSERS=["123456789"]

# --- Bot identity ---
master_id=123456789
bot_user_id=123456789

# --- Database ---
SQLALCHEMY_DATABASE_URL=${DB_URL}

# --- AI Core service (use global variable) ---
AI_CORE_URL=${AI_CORE_URL}

# --- Baidu Translation (use global variables) ---
baidu_trans_appid=${BAIDU_TRANS_APPID}
baidu_trans_apikey=${BAIDU_TRANS_APIKEY}

# --- Weather ---
QWEATHER_APIKEY=${QWEATHER_APIKEY}
QWEATHER_APITYPE=0

# --- FFmpeg ---
FFMPEG=ffmpeg

# --- Hippocampus context delegation (0=off, 1=on) ---
USE_HIPPOCAMPUS=${USE_HIPPOCAMPUS}
