# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Runtime config (may contain api keys; example files are tracked)
config/providers.json
config/mcp_servers.json

# Embedding legacy backups (auto-generated by migrate.py)
embedding/**/*.pkl.bak
embedding/**/vector/*.bak

# Image cache (download cache for url-based images)
images_cache/

# Media cache (url downloads, GIF→MP4 conversions)
media_cache/
gif_cache/

# Logs
*.log
logs/*
!logs/.gitkeep
